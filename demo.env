##################### 微服务配置 ######################
#服务配置参数(Consul)
CONSUL_CONTAINER_NAME=micro_device_config
CONSUL_VERSION=1.15.4
CONSUL_HOST=localhost
CONSUL_HTTP_PORT=8500
CONSUL_DNS_PORT=8600
#####################################################

##################### 数据库配置 ######################
# 数据库版本(PostgreSQL)
POSTGRES_CONTAINER_NAME=micro_device_db
POSTGRE_VERSION=16.14
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=123456


## IAM 微服务配置参数
POSTGRES_IAM_DB=micro_iam
POSTGRES_IAM_DATABASE_URL=postgresql://user:123456@localhost:5432/micro_iam

## AUTHN 微服务配置参数
POSTGRES_AUTHN_DB=micro_authn
POSTGRES_AUTHN_DATABASE_URL=postgresql://user:123456@localhost:5432/micro_authn

## AUTHZ 微服务配置参数
POSTGRES_AUTHZ_DB=micro_authz
POSTGRES_AUTHZ_DATABASE_URL=postgresql://user:123456@localhost:5432/micro_authz
#####################################################



##################### 值缓存配置 ######################
## 单机独立模式 ##
# REDIS_CONTAINER_NAME=micro_redis
# REDIS_VERSION=7.4-alpine
# REDIS_PREFIX=micro
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=123456
# REDIS_DB=0
# REDIS_TZ=Asia/Shanghai

## 哨兵主从模式 ##
REDIS_MASTER_CONTAINER_NAME=micro_device_master
REDIS_SLAVE_CONTAINER_NAME=micro_device_slave
REDIS_SENTINEL_CONTAINER_NAME=micro_device_sentinel
REDIS_VERSION=7.4-alpine
REDIS_PREFIX=micro
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0
REDIS_TZ=Asia/Shanghai
REDIS_SENTINEL_PORT=26379

## 标准: 1主2从3哨兵
## 哨兵: 哨兵投票过半，自动选择从节点升级为主节点。

## 集群分片模式 ##
## 最低标配: 3主3从，即1主带1从。
